# expect: true
# Probe 24: Generic binary search tree with Ord operations

type BST[a] = Leaf | Node(BST[a], a, BST[a])

bstInsert(tree, x) = match tree {
    Leaf -> Node(Leaf, x, Leaf)
    Node(left, val, right) ->
        if x < val then Node(bstInsert(left, x), val, right)
        else if x > val then Node(left, val, bstInsert(right, x))
        else tree
}

bstContains(tree, x) = match tree {
    Leaf -> false
    Node(left, val, right) ->
        if x == val then true
        else if x < val then bstContains(left, x)
        else bstContains(right, x)
}

bstToList(tree) = match tree {
    Leaf -> []
    Node(left, val, right) -> bstToList(left) ++ [val] ++ bstToList(right)
}

buildBST(xs) = xs.fold(Leaf, (t, x) => bstInsert(t, x))

main() = {
    t = buildBST([5, 3, 7, 1, 4, 6, 8])
    sorted = bstToList(t)
    hasThree = bstContains(t, 3)
    noNine = !bstContains(t, 9)
    isSorted = sorted == [1, 3, 4, 5, 6, 7, 8]
    hasThree && noNine && isSorted
}
