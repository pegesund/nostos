# expect: [6, 4, 2]
# Tests chaining two user-defined generic functions via UFCS
# Previously failed because instantiate_function's HasMethod constraints
# were not processed, leaving the intermediate return type unresolved.
double(xs) = xs.map(x => x * 2)
myReverse(xs) = xs.reverse()
main() = [1, 2, 3].double().myReverse()
