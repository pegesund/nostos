# expect: done
# Test: Two variant types with the same constructor name can coexist.
# IntTree and StrTree both have a Node constructor; inference must disambiguate
# based on context (function return type hint from match scrutinee/result).
type IntTree = Leaf | Node(Int, IntTree, IntTree)
type StrTree = StrLeaf | Node(String, StrTree, StrTree)

insertInt(t, v) =
  match t {
    Leaf -> Node(v, Leaf, Leaf)
    Node(x, l, r) -> if v < x then Node(x, insertInt(l, v), r) else Node(x, l, insertInt(r, v))
  }

insertStr(t, v) =
  match t {
    StrLeaf -> Node(v, StrLeaf, StrLeaf)
    Node(x, l, r) -> if v < x then Node(x, insertStr(l, v), r) else Node(x, l, insertStr(r, v))
  }

main() = {
  t1 = insertInt(Leaf, 5)
  t2 = insertStr(StrLeaf, "hello")
  "done"
}
