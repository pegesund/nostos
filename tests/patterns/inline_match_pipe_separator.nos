# expect: 0
# Regression: match arms can be separated by | on a single line
main() = {
  r1 = match Some(42) { Some(v) -> v | None -> 0 }
  assert_eq(42, r1)

  r2 = match None { Some(v) -> v | None -> -1 }
  assert_eq(-1, r2)

  # Also in lambda
  f = x => match x { Some(v) -> v * 2 | None -> 0 }
  assert_eq(10, f(Some(5)))
  assert_eq(0, f(None))

  0
}
