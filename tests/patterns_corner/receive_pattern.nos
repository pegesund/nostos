# expect: 42
# Pattern matching in receive — use wildcard catch-all per arm

type Msg = Ping(Int) | Pong | Data(String)

main() = {
    me = self()

    spawn { me <- Ping(5) }
    spawn { me <- Pong }
    spawn { me <- Data("hello") }

    # Receive 3 messages, accept any type (order may vary)
    var count = 0
    receive { _ -> count = count + 1 }
    receive { _ -> count = count + 1 }
    receive { _ -> count = count + 1 }

    if count == 3 then 42 else 0
}
