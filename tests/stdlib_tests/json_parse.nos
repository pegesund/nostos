# expect: true
# Tests JSON parsing module

use stdlib.json.{jsonParse, Null, Bool, Number, Integer, String, Array, Object}

main() = {
    # Simple values
    j1 = jsonParse("null")
    assert_eq(j1, Null)

    j2 = jsonParse("123")
    assert_eq(j2, Integer(123))

    # Negative numbers
    j2a = jsonParse("-42")
    assert_eq(j2a, Integer(-42))

    j2b = jsonParse("-1")
    assert_eq(j2b, Integer(-1))

    # Float numbers
    j2c = jsonParse("3.14")
    assert_eq(j2c, Number(3.14))

    j2d = jsonParse("-2.5")
    assert_eq(j2d, Number(-2.5))

    j2e = jsonParse("0.123")
    assert_eq(j2e, Number(0.123))

    j3 = jsonParse("\"hello\"")
    assert_eq(j3, String("hello"))

    j4 = jsonParse("true")
    assert_eq(j4, Bool(true))

    j5 = jsonParse("false")
    assert_eq(j5, Bool(false))

    # Array
    j6 = jsonParse("[1, 2, 3]")
    assert_eq(j6, Array([Integer(1), Integer(2), Integer(3)]))

    # Array with negative numbers
    j6a = jsonParse("[-1, 0, -99]")
    assert_eq(j6a, Array([Integer(-1), Integer(0), Integer(-99)]))

    # Array with floats
    j6b = jsonParse("[1.5, 2.25, 3.0]")
    assert_eq(j6b, Array([Number(1.5), Number(2.25), Number(3.0)]))

    # Object
    j7 = jsonParse("{\"key\": \"value\", \"num\": 42}")
    assert_eq(j7, Object([("key", String("value")), ("num", Integer(42))]))

    # Object with float
    j7a = jsonParse("{\"pi\": 3.14159}")
    assert_eq(j7a, Object([("pi", Number(3.14159))]))

    # Nested
    j8 = jsonParse("{\"list\": [1, 2], \"flag\": true}")
    expected = Object([
        ("list", Array([Integer(1), Integer(2)])),
        ("flag", Bool(true))
    ])
    assert_eq(j8, expected)

    true
}
