# expect: (6, 42, 4, 7)
# Local function definitions with wildcard _ parameters
main() = {
  ignoreSecond(x, _) = x + 1
  ignoreFirst(_, x) = x + 1
  ignoreOnly(_) = 42
  ignoreMid(a, _, c) = a + c

  a = ignoreSecond(5, "unused")
  b = ignoreOnly("anything")
  c = ignoreMid(1, "skip", 3)
  d = ignoreFirst("skip", 6)
  (a, b, c, d)
}
