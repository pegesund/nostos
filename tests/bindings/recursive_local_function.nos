# expect: passed
# Tests that local function definitions can be recursive.
# Local functions are desugared to lambdas (f(x) = body => f = (x) => body)
# and recursive self-reference requires a mutable cell for the closure capture.

main() = {
  # Simple recursive local function
  factorial(n) = if n <= 1 then 1 else n * factorial(n - 1)
  assert_eq(120, factorial(5))

  # Recursive accumulator pattern
  sumTo(n) = {
    go(acc, i) = if i <= 0 then acc else go(acc + i, i - 1)
    go(0, n)
  }
  assert_eq(55, sumTo(10))

  # Recursive local lambda binding
  fib = (n) => if n <= 1 then n else fib(n - 1) + fib(n - 2)
  assert_eq(8, fib(6))

  # Recursive local function with list building
  repeat(x, n) = {
    build(acc, remaining) = if remaining <= 0 then acc else build([x] ++ acc, remaining - 1)
    build([], n)
  }
  assert_eq([7, 7, 7], repeat(7, 3))

  # Non-recursive local function (should still work)
  double(x) = x * 2
  assert_eq(10, double(5))

  "passed"
}
